generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Complaint {
  id          Int      @id @default(autoincrement())
  phoneNumber String
  profileName String?
  remark      String?
  imageUrl    String?
  latitude    Float?
  longitude   Float?
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
